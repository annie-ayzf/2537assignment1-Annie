<li class="user-row">
    <span class="user-name">
        <%= user.name %>
        <% if (user.user_type === "admin") { %>
            (admin)
        <% } else {%>
            (user)
        <% } %>
    </span>

    <form action="/promote/<%= user._id %>" method='POST'>
        <button class="promote-btn btn btn-primary py-2" type="submit">Promote to Admin</button>
    </form>

    <form action="/demote/<%= user._id %>" method='POST'>
        <button class="demote-btn btn btn-primary py-2" type="submit">Demote to User</button>
    </form>

</li>


       